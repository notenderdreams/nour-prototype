Executable sandbox_app = {
    .sources = {
        "src/*.c",
        "src/utils/*.c",
    },
    .includes = { "." },
    .deps = { &math_utils, &example_cstatic, &example_cdynamic },
};

Project DemoProject = {
    .version = "0.1.0",
    .cc = "gcc",
    .build_dir = "build",
    .targets = { &sandbox_app, &math_utils_shared },
};

Profile debug = {
    .optimize = OPT_DEBUG,
    .warnings = WARN_ALL | WARN_EXTRA,
    .sanitizers = SAN_NONE,
    .cflags = { "-I." },
};

