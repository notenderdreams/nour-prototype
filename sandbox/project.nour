#include "nour.h"

Project sandbox_app = {
    .version = "0.1.0",
    .cc = "gcc",
    .sources = {
        "sandbox/*.c",
        "sandbox/math/*.c",
        "sandbox/utils/*.c"
    },
};

Profile debug = {
    .optimize = OPT_DEBUG,
    .warnings = WARN_ALL | WARN_EXTRA,
    .sanitizers = SAN_NONE,
    .cflags = { "-Isandbox" }
};

